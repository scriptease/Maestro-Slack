# Slack credentials
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_TEAM_ID=your-team-id-here
SLACK_APP_ID=your-app-id-here

# Optional: User whitelist (comma-separated user IDs)
SLACK_ALLOWED_USER_IDS=

# API server port
API_PORT=3457

# Socket Mode (development) — provides webhook-free operation via Slack's WebSocket protocol
# Get token from your Slack app settings under "Socket Mode"
# When set, the bot uses Socket Mode and ignores SLACK_BOT_PUBLIC_URL
# Example: SLACK_SOCKET_MODE_TOKEN=xapp-1-XXXXXXXXXXXX-XXXXXXXXXXXX-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SOCKET_MODE_TOKEN=

# Public-facing URL for the Slack bot (webhook mode, production)
# Only needed if not using Socket Mode. Used by update-manifest script to configure app_manifest.json
# This should be the externally accessible URL where your bot is deployed
# Example: http://example.com:3457 or http://scriptease.dynv6.net:3457
# Usage: SLACK_BOT_PUBLIC_URL=http://your-domain:3457 npm run update-manifest
SLACK_BOT_PUBLIC_URL=
